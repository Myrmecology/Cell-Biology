### =====================================================
### SECURITY: Secrets, Credentials, Keys, YubiKey/GPG/SSH
### =====================================================
# Environment / secret files — every variation
.env
.env.*
!.env.example
!.env.*.example
*.env
*.env.local
*.env.development
*.env.production
*.env.test
secrets/
secret.*
*.secret
*credentials*
*.credentials

# API keys / tokens
*apikey*
*api_key*
*.token
.npmrc

# GPG / PGP keys and keyrings (used with YubiKey OpenPGP applet)
*.gpg
*.pgp
*.asc
*.kbx
secring.*
pubring.*
.gnupg/
*.gpg-agent
gpg-agent.conf

# SSH keys (including those backed by YubiKey PIV/FIDO2 resident keys)
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
id_ecdsa
id_ecdsa.*
*.pem
*.key
*.ppk
known_hosts
authorized_keys
.ssh/

# YubiKey / PIV / PKCS#11 / smart card artifacts
*.p12
*.pfx
*.p8
*.pk8
*.csr
*.crt
*.cer
*.der
*yubikey*
*piv-cert*
pkcs11.conf
opensc*.conf

# FIDO2 / WebAuthn credential exports (if ever dumped locally for debugging)
*fido2*credential*
*webauthn*credential*

# Signing / commit verification artifacts that shouldn't be shared
*.gpgsign
.git-crypt/

