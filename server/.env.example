# Server configuration
PORT=3001
NODE_ENV=development

# Allowed origin for CORS — the client dev server's URL.
# Update this to your production domain when deploying.
CLIENT_ORIGIN=http://localhost:5173

# Gemini API key for the AI tutor feature.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Note: the science image feature uses the Wikimedia Commons API, which
# is fully public and requires no API key at all.

# Basic rate limiting for the public-facing proxy endpoints
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20